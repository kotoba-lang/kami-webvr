{:paths ["src"]
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :shadow {:extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}
                        thheller/shadow-cljs      {:mvn/version "2.28.20"}}}
  ;; shadow-cljs's :node-test build's classpath needs cljs-test/ added, kept
  ;; separate from :test (which cognitect.test-runner scans on the JVM) since
  ;; cljs-test/ uses cljs.test/npm-only syntax -- same split kami-genko uses.
  :cljs-test {:extra-paths ["cljs-test"]}}}
