;; kami-webvr — cljs builds.
;;   :node-test — the cine-bridge/engine cljs.test suite (node environment,
;;     no browser needed; `js/fetch`/`js/document` are absent under plain
;;     node, exercising the graceful-degradation paths on purpose).
{:deps   {:aliases [:shadow :cljs-test]}
 :builds
 {:node-test
  {:target :node-test
   :output-to "out/kami-webvr-tests.js"
   :ns-regexp "^kami\\.webvr\\..*-test$"}}}
